# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# production
/build
/dist

# generated service worker bundles (built from src/sw.ts)
/public/sw.js
/public/sw-*.js
/public/sw-*.js.map

# legacy worker build artifacts (tsc outDir)
/public/workers/
/public/storage/
/public/utils/
/public/error.js
/public/error.js.map

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# local dev certs (nginx)
/infra/nginx-test/certs/*.key
/infra/nginx-test/certs/*.crt
/infra/nginx-test/certs/*.pem

# typescript
*.tsbuildinfo

# macOS
.DS_Store
test.json